      "field": "type_of_organisation",
      "notEquals": "1",
      "source": "ClientValidatePan() JS function, confirmed earlier"
    },
    "validators": [
      {
        "validatorId": "ctl00_ContentPlaceHolder1_rfvpannumber",
        "errorMessage": "Required"
      },
      {
        "validatorId": "ctl00_ContentPlaceHolder1_RegularExpressionValidator5",
        "errorMessage": "Invalid PAN Card",
        "validationExpression": null,
        "notes": "Expression not present in this HTML snippet - use assignment-provided pattern ^[A-Za-z]{5}[0-9]{4}[A-Za-z]{1}$"
      }
    ]
  },
  {
    "tag": "input",
    "id": "ctl00_ContentPlaceHolder1_txtPanName",
    "name": "ctl00$ContentPlaceHolder1$txtPanName",

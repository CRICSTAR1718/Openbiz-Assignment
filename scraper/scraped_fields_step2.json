    "containerVisibleByDefault": false,
    "required": true,
    "onchange": "resetValidationState(this)",
    "validators": [
      {
        "validatorId": "ctl00_ContentPlaceHolder1_RequiredFieldValidator50",
        "errorMessage": "Required"
      }

    "validators": [
      {
        "validatorId": "ctl00_ContentPlaceHolder1_CustomValidator5",
        "errorMessage": "Invalid date"
      },
      {
        "validatorId": "ctl00_ContentPlaceHolder1_RequiredFieldValidator55",
        "errorMessage": "Required"
      },
      {
        "validatorId": "ctl00_ContentPlaceHolder1_RegularExpressionValidator7",
        "errorMessage": "Date format is DD/MM/YYYY",
        "validationExpression": null,
        "notes": "Expression not present in this HTML snippet - implement as DD/MM/YYYY regex, e.g. ^([0-2][0-9]|3[01])/(0[1-9]|1[0-2])/[0-9]{4}$"
      }

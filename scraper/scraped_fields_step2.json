    "options": [
      { "id": "ctl00_ContentPlaceHolder1_rbpanyesno_0", "value": "1", "label": "Yes", "checkedByDefault": true },
      { "id": "ctl00_ContentPlaceHolder1_rbpanyesno_1", "value": "2", "label": "No", "onclick": "triggers __doPostBack on select" }
    ]
  },
  {
    "tag": "input",
    "id": "ctl00_ContentPlaceHolder1_txtPan",

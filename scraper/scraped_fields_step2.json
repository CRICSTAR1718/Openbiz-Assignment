    "maxlength": "100",
    "placeholder": "Name as per PAN",
    "autocomplete": "Off",
    "required": true,
    "validators": [
      {
        "validatorId": "ctl00_ContentPlaceHolder1_RequiredFieldValidator53",
        "errorMessage": "Required"
      }
    ]
  },
  {
    "tag": "input",
    "id": "ctl00_ContentPlaceHolder1_txtdob",
    "name": "ctl00$ContentPlaceHolder1$txtdob",
    "type": "text",
    "label": "4.1.2 DOB or DOI (Date of Incorporation) as per PAN",
